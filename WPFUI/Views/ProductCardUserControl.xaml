<UserControl x:Class="TLGames.WPFUI.Views.ProductCardUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:controls="clr-namespace:TLGames.WPFUI.Views"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="322"
             d:HorizontalAlignment="Left"
             d:VerticalAlignment="Top">
    <ui:Card x:Name="CProduct" Height="250" Width="350" Background="#FFFF4B4B" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="Hand">
        <StackPanel x:Name="stackPanel">
            <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="200" >
                <Image x:Name="IProduct" 
                       Source="{Binding ImageSource}" 
                       Cursor="Hand" 
                       Height="Auto" 
                       VerticalAlignment="Top" 
                       HorizontalAlignment="Left" 
                       Stretch="Fill" />
            </Border>

            <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TProductName" 
                           Text="{Binding ProductName}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           TextWrapping="Wrap" 
                           Margin="0,10,0,0" />

                <TextBlock x:Name="TProductPrice" 
                           Text="{Binding ProductPrice, StringFormat={}{0:N3} VNĐ}" 
                           FontSize="14" 
                           Foreground="LightGray" 
                           HorizontalAlignment="Center" 
                           Margin="0,2,0,0" />
            </StackPanel>
        </StackPanel>
    </ui:Card>
</UserControl>
