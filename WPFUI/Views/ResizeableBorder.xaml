<UserControl x:Class="TLGames.WPFUI.Views.ResizeableBorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TLGames.WPFUI.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Rectangle Name="TopLeft" HorizontalAlignment="Left" VerticalAlignment="Top" Width="20" Height="20" Cursor="SizeNWSE" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="TopRight" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Cursor="SizeNESW" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="BottomLeft" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="20" Height="20" Cursor="SizeNESW" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="BottomRight" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="20" Height="20" Cursor="SizeNWSE" MouseDown="Resize_MouseDown" Fill="Transparent"/>

        <Rectangle Name="Top" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="4" Cursor="SizeNS" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="Bottom" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="4" Cursor="SizeNS" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="Left" VerticalAlignment="Stretch" HorizontalAlignment="Left" Width="4" Cursor="SizeWE" MouseDown="Resize_MouseDown" Fill="Transparent"/>
        <Rectangle Name="Right" VerticalAlignment="Stretch" HorizontalAlignment="Right" Width="4" Cursor="SizeWE" MouseDown="Resize_MouseDown" Fill="Transparent"/>

    </Grid>
</UserControl>