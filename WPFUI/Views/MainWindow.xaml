<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TLGames"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
        x:Name="Main" 
        x:Class="TLGames.MainWindow" 
        Icon="/WPFUI/Resources/images/icons/web_logo/main-logo.jpg"
        xmlns:controls="clr-namespace:TLGames.WPFUI.Views" 
        xmlns:local1="clr-namespace:TLGames.Core.Entities" 
        xmlns:viewmodels="clr-namespace:TLGames.WPFUI.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="TLGames"
        Height="1080"
        Width="1920"
        Topmost="False"
        WindowStartupLocation="CenterScreen"
        Cursor="Arrow"
        FontFamily="Arial"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="Transparent"
        BorderThickness="0"
        AllowDrop="True" ResizeMode="CanResize">
    <Window.Background>
        <SolidColorBrush Color="White" Opacity="0"/>
    </Window.Background>
    <Window.Foreground>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0.1"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Foreground>
    <Border x:Name="BrMainForm" BorderThickness="1,1,1,1" CornerRadius="6" BorderBrush="#FF4595FF">
        <Border.Background>
            <LinearGradientBrush EndPoint="1,2" StartPoint="0,-1">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FFC2CBFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid x:Name="GMainContainer" Margin="0,0,-2,-2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="537*"/>
                <ColumnDefinition Width="103*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="68"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid x:Name="GHeaderForm" Grid.Row="0" Grid.ColumnSpan="2" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="SPControlForm" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Height="40" Width="120">
                    <ui:Card x:Name="CMinimizeContainer" HorizontalAlignment="Left" Cursor="Hand" Width="40">
                        <Image x:Name="ImgMinimizeButton" Source="/WPFUI/Resources/images/icons/other_icons/icons8-minimize-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20"/>
                    </ui:Card>
                    <ui:Card x:Name="CToggleFullScreenContainer" HorizontalAlignment="Center" Cursor="Hand" VerticalAlignment="Center" Width="40" Height="40">
                        <Image x:Name="ImgFullScreenButton" Source="/WPFUI/Resources/Images/icons/buttons/icons8-toggle-full-screen-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20"/>
                    </ui:Card>
                    <ui:Card x:Name="CExitFormContainer" Width="40" HorizontalAlignment="Center" VerticalContentAlignment="Center" Cursor="Hand">
                        <Image x:Name="ImgExitFormButton" Source="/WPFUI/Resources/Images/icons/buttons/icons8-exit-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20"/>
                    </ui:Card>
                </StackPanel>
                <StackPanel x:Name="SPHeaderMenu" Orientation="Horizontal" VerticalAlignment="Center" Height="40" HorizontalAlignment="Center" Width="638">
                    <ui:Card x:Name="CMainMenuIcon">
                        <Grid x:Name="CMainIconContainer" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40*"/>
                                <ColumnDefinition Width="79*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Card x:Name="CMainImage" Cursor="Hand" HorizontalAlignment="Center" Width="41">
                                <Image x:Name="ImgMainImage" Height="30" Width="30" Source="/WPFUI/Resources/Images/icons/web_logo/main-logo.jpg" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ui:Card>
                            <ui:Card x:Name="CMainHeaderText" Content="TLGames" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                        </Grid>
                    </ui:Card>
                    <ui:Card x:Name="CNavToFriends" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToFriends" Content="Friends" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FFFFF8F8" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToGames" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToGames" Content="Games" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FF707070" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToCommunity" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToCommunity" Content="Community" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="White" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToHelp" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToHelp" Content="Help" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FF707070" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="SPSupHeader" Grid.Row="1" Height="50" VerticalAlignment="Center" Grid.ColumnSpan="2">
                <Grid x:Name="GSupHeaderContainer" Height="{Binding ActualHeight, ElementName=SPSupHeader, Mode=OneWay}" Width="{Binding ActualWidth, ElementName=SPSupHeader, Mode=OneWay}">
                    <Border x:Name="BStackFuncs" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Padding="10,0,10,0" CornerRadius="6,6,6,6">
                        <Border.Background>
                            <LinearGradientBrush EndPoint="0,4" StartPoint="2,-1">
                                <GradientStop Color="Black" Offset="0"/>
                                <GradientStop Color="#FF6789DE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid HorizontalAlignment="Center" Margin="0,3,0,3">
                            <StackPanel x:Name="SPSubHeaderFuncs" Orientation="Horizontal" HorizontalAlignment="Left" Height="24" VerticalAlignment="Center">
                                <Border x:Name="BCategories" Width="100" Margin="0,0,10,0" Background="#FFC7D0FF" BorderThickness="1,1,1,1" CornerRadius="4,4,4,4" HorizontalAlignment="Center" Cursor="Hand" >
                                    <Button x:Name="BtnCategories" Content="Categories" Cursor="Hand" Background="{x:Null}" BorderBrush="{x:Null}" VerticalAlignment="Center" Margin="18,0,0,0" HorizontalAlignment="Left" Width="62"/>
                                </Border>
                                <Border x:Name="BNews" Width="100" Margin="{Binding Margin, ElementName=BCategories}" BorderThickness="1,1,1,1" CornerRadius="4,4,4,4" Background="#FFC7D0FF" HorizontalAlignment="Center" Cursor="Hand" >
                                    <Button x:Name="BtnNews" Content="News" Cursor="{Binding Cursor, ElementName=BtnCategories}" BorderBrush="{x:Null}" Background="{x:Null}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="BHistoryPurchase" Width="100" Margin="{Binding Margin, ElementName=BCategories}" BorderThickness="1,1,1,1" CornerRadius="4,4,4,4" Background="#FFC7D0FF" HorizontalAlignment="Center" Cursor="Hand" >
                                    <Button x:Name="BtnHistoryPurchase" Content="History Purchase" Cursor="{Binding Cursor, ElementName=BtnCategories}" BorderBrush="{x:Null}" Background="{x:Null}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="BCart" Width="100" Margin="{Binding Margin, ElementName=BCategories}" CornerRadius="4,4,4,4" BorderThickness="1,1,1,1" Background="#FFC7D0FF" HorizontalAlignment="Center" Cursor="Hand">
                                    <Button x:Name="BtnCart" Content="Cart" Cursor="{Binding Cursor, ElementName=BtnCategories}" Background="{x:Null}" BorderBrush="{x:Null}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                            <StackPanel x:Name="SPHeaderSearch" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="638,0,0,0" Height="{Binding ActualHeight, ElementName=SPSubHeaderFuncs, Mode=OneWay}">
                                <WrapPanel x:Name="WPSearchContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Height="24">
                                    <Border x:Name="BrHeaderSearchContainer" BorderBrush="#FFA6C0FF" BorderThickness="1" VerticalAlignment="Center" CornerRadius="4,4,4,4" Background="Black" HorizontalAlignment="Center" Width="300">
                                        <ui:TextBox x:Name="TbHeaderSearch" TextWrapping="Wrap" Text="Search Product" SelectionTextBrush="#FFFFB4B4" Background="{x:Null}" BorderBrush="{x:Null}" Height="{Binding ActualHeight, ElementName=SPHeaderSearch, Mode=OneWay}" VerticalContentAlignment="Center" Padding="4,0,0,0">
                                            <ui:TextBox.Foreground>
                                                <SolidColorBrush Color="White" Opacity="1"/>
                                            </ui:TextBox.Foreground>
                                            <ui:TextBox.SelectionBrush>
                                                <SolidColorBrush Color="#FF79B4DA" Opacity="1"/>
                                            </ui:TextBox.SelectionBrush>
                                        </ui:TextBox>
                                    </Border>
                                    <Border x:Name="BrHeaderSearchButtonContainer" BorderThickness="1" CornerRadius="4,4,4,4" Background="#FF2D5A82" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0,0,0" Width="24">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#FFA6C0FF" Opacity="1"/>
                                        </Border.BorderBrush>
                                        <ui:Button x:Name="BtnSearchProduct" Background="{x:Null}" BorderBrush="{x:Null}" Width="{Binding ActualWidth, ElementName=BrHeaderSearchButtonContainer, Mode=OneWay}" Height="{Binding ActualHeight, ElementName=BrHeaderSearchButtonContainer, Mode=OneWay}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-1,0,0,0">
                                            <Image x:Name="ImgSearchButton" Stretch="Fill" Source="/WPFUI/Resources/images/icons/buttons/icons8-search-40.png" Cursor="Hand" Width="{Binding ActualWidth, ElementName=BtnSearchProduct, Mode=OneWay}" Height="{Binding ActualHeight, ElementName=BtnSearchProduct, Mode=OneWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </ui:Button>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
            <Grid x:Name="GMainContent" Margin="10,0,10,10" Grid.Row="2" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar - Steam Style -->
                <Border Grid.Column="0" Background="#1b2838" BorderBrush="#2a475e" 
                    BorderThickness="1" CornerRadius="5" Margin="0,0,10,0">
                    <StackPanel Margin="10">
                        <!-- Navigation Buttons -->
                        <Button Content="New &amp; Trending" Style="{StaticResource ActiveButtonStyle}"/>
                        <Button Content="Top Sellers" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Popular Upcoming" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Specials" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Trending Free" Style="{StaticResource SteamButtonStyle}"/>

                        <Separator Background="#2a475e" Margin="0,10" Height="1"/>

                        <!-- Browse Categories -->
                        <TextBlock Text="Browse by genre" Foreground="#8f98a0" FontSize="11" Margin="0,10,0,5"/>
                        <Button Content="Action" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Adventure" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Strategy" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="RPG" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Simulation" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Sports" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Racing" Style="{StaticResource SteamButtonStyle}"/>
                        <Button Content="Family Friendly" Style="{StaticResource SteamButtonStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Main Content Area -->
                <Grid x:Name="GListProductContainer" Grid.Column="1" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Banner/Featured Section -->
                    <Border x:Name="BMainEvent" Grid.Row="0" Background="#2a475e" CornerRadius="5" Margin="0,0,0,10" Height="200">
                        <Grid x:Name="GMainEventContainer">
                            <Rectangle Opacity="0.8">
                                <Rectangle.Fill>
                                    <LinearGradientBrush EndPoint="0.5,2" StartPoint="0.5,0">
                                        <GradientStop Color="Black"/>
                                        <GradientStop Color="#FFC2CBFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <StackPanel x:Name="SPRecommend" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20">
                                <TextBlock x:Name="TextRecommend" Text="Featured &amp; Recommended" FontSize="24" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Special offers and great games" FontSize="14" Foreground="#b8b6b4"/>
                            </StackPanel>
                            <StackPanel x:Name="SPDealLabel" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="20">
                                <Border Background="#4c6b22" CornerRadius="3" Padding="8,4">
                                    <TextBlock Text="WEEKEND DEAL" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Product List -->
                    <ScrollViewer x:Name="SVListProduct" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="ProductListContainer">

                            <!-- Product 1: Prison Escape Simulator -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="Prison Escape Simulator: Dig Out" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Style="{StaticResource DiscountBadgeStyle}">
                                                <TextBlock Text="-15%" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Simulation, Exploration, Life Sim, Crime" 
                                                FontSize="11" Foreground="#8f98a0" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="25 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="255.500₫" Style="{StaticResource OriginalPriceStyle}"/>
                                        <TextBlock Text="74.500₫" Style="{StaticResource SalePriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 2: No Sleep For Kaname Date -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="No Sleep For Kaname Date - From AI: THE S" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Adventure, Visual Novel, Interactive Fiction, Choose Your Own Adventure" 
                                            FontSize="11" Foreground="#8f98a0" Margin="0,2,0,0"/>
                                        <TextBlock Text="25 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="470.000₫" Style="{StaticResource RegularPriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 3: Let Them Trade -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="Let Them Trade" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Style="{StaticResource DiscountBadgeStyle}">
                                                <TextBlock Text="-26%" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="City Builder, Relaxing, Resource Management, Real Time Tactics" 
                                                FontSize="11" Foreground="#8f98a0" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="24 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="255.500₫" Style="{StaticResource OriginalPriceStyle}"/>
                                        <TextBlock Text="188.000₫" Style="{StaticResource SalePriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 4: The Great Villainess -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="The Great Villainess: Strategy of Lily" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Style="{StaticResource DiscountBadgeStyle}">
                                                <TextBlock Text="-10%" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Turn-Based Tactics, Tactical RPG, Female Protagonist" 
                                                FontSize="11" Foreground="#8f98a0" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="24 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="385.000₫" Style="{StaticResource OriginalPriceStyle}"/>
                                        <TextBlock Text="346.500₫" Style="{StaticResource SalePriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 5: SUPERVIVE -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="SUPERVIVE" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Battle Royale, MOBA, Hero Shooter, PvP" 
                                            FontSize="11" Foreground="#8f98a0" Margin="0,2,0,0"/>
                                        <TextBlock Text="24 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <Border Background="#5c7e10" CornerRadius="3" Padding="8,4">
                                            <TextBlock Text="Free" FontSize="14" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 6: Wheel World -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="Wheel World" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Style="{StaticResource DiscountBadgeStyle}">
                                                <TextBlock Text="-10%" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Adventure, Sports, Racing, Bikes" 
                                                FontSize="11" Foreground="#8f98a0" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="23 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="250.000₫" Style="{StaticResource OriginalPriceStyle}"/>
                                        <TextBlock Text="225.000₫" Style="{StaticResource SalePriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Product 7: Animal Shelter 2 -->
                            <Border Style="{StaticResource ProductItemStyle}">
                                <Grid Height="69">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="184"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#2a475e">
                                        <TextBlock Text="GAME IMAGE" FontSize="12" Foreground="#8f98a0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="10,8,10,8" VerticalAlignment="Center">
                                        <TextBlock Text="Animal Shelter 2" FontSize="14" FontWeight="SemiBold" 
                                            Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <Border Style="{StaticResource DiscountBadgeStyle}">
                                                <TextBlock Text="-29%" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="Simulation, Family Friendly, Multiplayer, Cute" 
                                                FontSize="11" Foreground="#8f98a0" Margin="8,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="23 Jul, 2025" FontSize="10" Foreground="#626366" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="15,8,15,8" VerticalAlignment="Center">
                                        <TextBlock Text="361.000₫" Style="{StaticResource OriginalPriceStyle}"/>
                                        <TextBlock Text="256.500₫" Style="{StaticResource SalePriceStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Right Panel - Game Details (Static for now) -->
                <Border x:Name="BRightPanel" Grid.Column="2" Background="#1e2329" BorderBrush="#2a475e" 
                    BorderThickness="1" CornerRadius="5">
                    <StackPanel x:Name="SPDetailProductContainer" Margin="15">
                        <TextBlock x:Name="TextProductName" Text="Prison Escape Simulator: Dig Out" 
                            FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <!-- Screenshot Gallery -->
                        <ScrollViewer x:Name="SVListProductImage" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Height="120" Margin="0,0,0,10">
                            <StackPanel x:Name="SPProductImage" Orientation="Horizontal" ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <Border Width="160" Height="90" Margin="0,0,5,0" Background="#2a475e" CornerRadius="3">
                                    <TextBlock Text="Screenshot 1" FontSize="10" Foreground="#8f98a0" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Width="160" Height="90" Margin="0,0,5,0" Background="#2a475e" CornerRadius="3">
                                    <TextBlock Text="Screenshot 2" FontSize="10" Foreground="#8f98a0" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Width="160" Height="90" Margin="0,0,5,0" Background="#2a475e" CornerRadius="3">
                                    <TextBlock Text="Screenshot 3" FontSize="10" Foreground="#8f98a0" 
                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- User Reviews -->
                        <TextBlock x:Name="TextUserReview" Text="User Reviews:" FontSize="12" FontWeight="SemiBold" Foreground="#8f98a0" Margin="0,0,0,5"/>
                        <StackPanel x:Name="SPProductRate" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Very Positive" FontSize="12" Foreground="#66c0f4"/>
                            <TextBlock Text=" (1,234 reviews)" FontSize="12" Foreground="#8f98a0"/>
                        </StackPanel>

                        <!-- Genre -->
                        <TextBlock x:Name="TextProductGenreLabel" Text="Genre:" FontSize="12" FontWeight="SemiBold" Foreground="#8f98a0" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TextProductGenre" Text="Simulation, Exploration, Life Sim, Crime" 
                            FontSize="12" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <!-- Release Date -->
                        <TextBlock x:Name="TextReleaseDateLabel" Text="Release Date:" FontSize="12" FontWeight="SemiBold" Foreground="#8f98a0" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TextReleaseDate" Text="25 Jul, 2025" FontSize="12" Foreground="White" Margin="0,0,0,15"/>

                        <!-- Price -->
                        <Border x:Name="BProductPrice" CornerRadius="3" Padding="8">
                            <Border.Background>
                                <LinearGradientBrush EndPoint="0.5,2" StartPoint="0.5,-1" SpreadMethod="Pad">
                                    <GradientStop Color="Black"/>
                                    <GradientStop Color="#FFC2CBFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel x:Name="SPProductPriceContainer">
                                <StackPanel x:Name="SPProductDiscountPrice" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border x:Name="BSaleValueLabel" Background="#4c6b22" CornerRadius="2" Padding="4,2" Margin="0,0,5,0">
                                        <TextBlock Text="-15%" FontSize="12" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="255.500₫" FontSize="12" Foreground="White" 
                                        TextDecorations="Strikethrough" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="TextProductPrice" Text="74.500₫" FontSize="16" Foreground="White" FontWeight="Bold" 
                                    HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Add to Cart Button -->
                        <Button x:Name="BtnAddToCart" Content="Add to Cart" Background="#4c6b22" Foreground="White" 
                            BorderThickness="0" Padding="0,12" Margin="0,10,0,0" 
                            FontSize="14" FontWeight="Bold" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="{x:Type Button}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type Button}">
                                                <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#5c7836"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
            <controls:ResizeableBorderUserControl Grid.RowSpan="3" Margin="0,0,7,0" d:IsHidden="True" Grid.ColumnSpan="2"/>
        </Grid>
    </Border>
</Window>

