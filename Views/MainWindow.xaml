<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TLGames"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Name="Main" x:Class="TLGames.MainWindow" Icon="/Resources/images/icons/web_logo/main-logo.jpg"
        xmlns:controls="clr-namespace:TLGames.Views"
        mc:Ignorable="d"
        Title="TLGames"
        Height="1080"
        Width="1920"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Cursor="Arrow"
        FontFamily="Arial"
        WindowStyle="None"
        AllowsTransparency="True"
        BorderBrush="Transparent"
        BorderThickness="0"
        AllowDrop="True" ResizeMode="CanResize">
    <Window.Background>
        <SolidColorBrush Color="White" Opacity="0"/>
    </Window.Background>
    <Window.Foreground>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="Black" Offset="0.1"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
    </Window.Foreground>
    <Border x:Name="BrMainForm" BorderBrush="Black" BorderThickness="0.25" CornerRadius="10">
        <Border.Background>
            <LinearGradientBrush EndPoint="1.25,2" StartPoint="0,0">
                <GradientStop Color="Black"/>
                <GradientStop Color="#FF5E9AFB" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid x:Name="GMainContainer" Margin="0,0,-2,-2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid x:Name="GHeaderForm" Grid.Row="0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="638"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="SPControlForm" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Height="40" Width="120" Margin="0,0,10,0">
                    <ui:Card x:Name="CMinimizeContainer" HorizontalAlignment="Left" Cursor="Hand" Width="40">
                        <Image x:Name="ImgMinimizeButton" Source="/Resources/Images/icons/buttons/icons8-minimize-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20"/>
                    </ui:Card>
                    <ui:Card x:Name="CToggleFullScreenContainer" HorizontalAlignment="Center" Cursor="Hand" VerticalAlignment="Center" Width="40" Height="40">
                        <Image x:Name="ImgFullScreenButton" Source="/Resources/Images/icons/buttons/icons8-toggle-full-screen-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20"/>
                    </ui:Card>
                    <ui:Card x:Name="CExitFormContainer" Width="40" HorizontalAlignment="Center" VerticalContentAlignment="Center" Cursor="Hand">
                        <Image x:Name="ImgExitFormButton" Source="/Resources/Images/icons/buttons/icons8-exit-40.png" HorizontalAlignment="Center" VerticalAlignment="Center" Width="20" Height="20"/>
                    </ui:Card>
                </StackPanel>
                <StackPanel x:Name="SPHeaderMenu" Orientation="Horizontal" VerticalAlignment="Center" Height="40" HorizontalAlignment="Left" Width="638" Margin="10,0,0,0">
                    <ui:Card x:Name="CMainMenuIcon">
                        <Grid x:Name="CMainIconContainer" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0" Cursor="Hand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40*"/>
                                <ColumnDefinition Width="79*"/>
                            </Grid.ColumnDefinitions>
                            <ui:Card x:Name="CMainImage" Cursor="Hand" HorizontalAlignment="Center" Width="41">
                                <Image x:Name="ImgMainImage" Height="30" Width="30" Source="/Resources/Images/icons/web_logo/main-logo.jpg" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ui:Card>
                            <ui:Card x:Name="CMainHeaderText" Content="TLGames" Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="White"/>
                        </Grid>
                    </ui:Card>
                    <ui:Card x:Name="CNavToFriends" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToFriends" Content="Friends" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FFFFF8F8" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToGames" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToGames" Content="Games" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FF707070" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToCommunity" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToCommunity" Content="Community" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="White" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                    <ui:Card x:Name="CNavToHelp" Margin="0,0,10,0" Cursor="Hand">
                        <ui:Button x:Name="BtnNavToHelp" Content="Help" Foreground="White">
                            <ui:Button.BorderBrush>
                                <SolidColorBrush Color="#FF707070" Opacity="0"/>
                            </ui:Button.BorderBrush>
                            <ui:Button.Background>
                                <SolidColorBrush Color="#FFDDDDDD" Opacity="0"/>
                            </ui:Button.Background>
                        </ui:Button>
                    </ui:Card>
                </StackPanel>
            </Grid>

            <StackPanel x:Name="SPSupHeader" Grid.Row="1" Height="100" VerticalAlignment="Top">
                <WrapPanel x:Name="WPSearchContainer" Height="32" Width="647">
                    <Border x:Name="BrHeaderSearchContainer" BorderBrush="#FFA6C0FF" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,10,0" CornerRadius="2" Background="#FF2D363E">
                        <ui:TextBox x:Name="TbHeaderSearch" TextWrapping="Wrap" Text="Search Product" Width="120" MinWidth="600" Height="30" VerticalContentAlignment="Center" Foreground="White" SelectionTextBrush="#FFFFDEDE" Background="{x:Null}" BorderBrush="{x:Null}">
                            <ui:TextBox.SelectionBrush>
                                <SolidColorBrush Color="#FF0078D7" Opacity="1"/>
                            </ui:TextBox.SelectionBrush>
                        </ui:TextBox>
                    </Border>
                    <Border x:Name="BrHeaderSearchButtonContainer" BorderBrush="#FFA6C0FF" BorderThickness="1" CornerRadius="5" Background="#FF2D363E" HorizontalAlignment="Center" Width="30" Height="30">
                        <ui:Card x:Name="CButtonHeaderSearch" Cursor="Hand" Foreground="{x:Null}" BorderThickness="1,1,1,1">
                            <ui:Card.Background>
                                <SolidColorBrush Color="#FFBADBFF" Opacity="0"/>
                            </ui:Card.Background>
                            <ui:Button x:Name="BtnHeaderSearch" Cursor="Hand" Foreground="White" Padding="0,0,0,0" Background="{x:Null}" Height="30" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <ui:Button.BorderBrush>
                                    <SolidColorBrush Color="#FFC8DDFF" Opacity="0"/>
                                </ui:Button.BorderBrush>
                                <Image Stretch="Fill" Source="/Resources/Images/icons/buttons/icons8-search-40.png" Width="30" HorizontalAlignment="Center" VerticalAlignment="Center" Height="30" Cursor="Hand"/>
                            </ui:Button>
                        </ui:Card>
                    </Border>
                </WrapPanel>
            </StackPanel>
            <Grid x:Name="GMainContent" Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80*"/>
                    <ColumnDefinition Width="295*"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="SPNavControl"/>
            </Grid>

            <controls:ResizeableBorder Grid.RowSpan="3"/>
        </Grid>
    </Border>
</Window>

