<Application x:Name="GHeaderForm" x:Class="TLGames.App"  
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
           xmlns:tb="http://www.hardcodet.net/taskbar"  
           xmlns:local="clr-namespace:TLGames"  
           xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"  
           StartupUri="WPFUI/Views/MainWindow.xaml"  
           xmlns:coreEntities="clr-namespace:TLGames.Core.Entities"
           ShutdownMode="OnExplicitShutdown">  
  <Application.Resources>  
      <tb:TaskbarIcon x:Key="HiddenIcon" IconSource="/WPFUI/Resources/images/icons/web_logo/main-logo.jpg"/>  
      <Style TargetType="ui:TextBox">  
          <EventSetter Event="GotKeyboardFocus" Handler="TextBox_GotKeyboardFocus"/>  
          <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TextBox_PreviewMouseLeftButtonDown"/>  
      </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!--<ControlTemplate.Triggers>  
                          <Trigger Property="IsMouseOver" Value="True">  
                              <Setter Property="Background" Value="#FFBADBFF"/>  
                          </Trigger>  
                          <Trigger Property="IsPressed" Value="True">  
                              <Setter Property="Background" Value="#FFA6C0FF"/>  
                          </Trigger>  
                      </ControlTemplate.Triggers>-->
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ui:CardAction">  
          <Setter Property="Background" Value="Transparent"></Setter>  
          <Setter Property="BorderBrush" Value="White"></Setter>  
          <Setter Property="BorderThickness" Value="0, 1, 0, 1"></Setter>  
          <Setter Property="FontSize" Value="14"></Setter>  
          <Setter Property="Template">  
              <Setter.Value>  
                  <ControlTemplate TargetType="ui:CardAction">  
                      <Border Background="Transparent"  
                              BorderBrush="{TemplateBinding BorderBrush}"  
                              BorderThickness="{TemplateBinding BorderThickness}">  
                          <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"  
                                            VerticalAlignment="Center"  
                                            Margin="5, 5, 0, 5"></ContentPresenter>  
                      </Border>  
                  </ControlTemplate>  
              </Setter.Value>  
          </Setter>  
      </Style>  

      <Style TargetType="ListBox">  
          <Setter Property="Background" Value="Transparent"></Setter>  
          <Setter Property="BorderBrush" Value="Transparent"></Setter>  
          <Setter Property="Foreground" Value="FloralWhite"></Setter>  
          <Setter Property="Opacity" Value="0.6"></Setter>  
          <Setter Property="Cursor" Value="Hand"></Setter>  
      </Style>   

      <!-- Style cơ bản cho TextBlock -->  
      <Style TargetType="TextBlock" x:Key="BaseTextBlockStyle">  
          <Setter Property="Foreground" Value="White"/>  
          <Setter Property="FontSize" Value="14"/>  
          <Setter Property="Margin" Value="0,2,0,0"/>  
      </Style>  

      <!-- Style cho tên sản phẩm -->  
      <Style TargetType="TextBlock" x:Key="ProductNameStyle" BasedOn="{StaticResource BaseTextBlockStyle}">  
          <Setter Property="FontSize" Value="16"/>  
          <Setter Property="FontWeight" Value="Bold"/>  
          <Setter Property="TextWrapping" Value="Wrap"/>  
          <Setter Property="MaxHeight" Value="36"/>  
          <!-- Giới hạn 2 dòng -->  
      </Style>  

      <!-- Style cho giá sản phẩm -->  
      <Style TargetType="TextBlock" x:Key="ProductPriceStyle" BasedOn="{StaticResource BaseTextBlockStyle}">  
          <Setter Property="FontSize" Value="15"/>  
          <Setter Property="Foreground" Value="#FFD700"/>  
          <!-- Màu vàng cho giá -->  
          <Setter Property="FontWeight" Value="SemiBold"/>  
      </Style>  

      <!-- Style cho đánh giá sản phẩm -->  
      <Style TargetType="TextBlock" x:Key="ProductRatingStyle" BasedOn="{StaticResource BaseTextBlockStyle}">  
          <Setter Property="FontSize" Value="13"/>  
          <Setter Property="Foreground" Value="#88FF88"/>  
          <!-- Màu xanh lá cây nhạt cho đánh giá -->  
          <Setter Property="FontWeight" Value="Medium"/>  
      </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="True"
                                          SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#43A047"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#A5D6A7"/>
                                <Setter Property="Foreground" Value="#DDDDDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate cho mỗi sản phẩm -->  
      <!--<DataTemplate DataType="{x:Type coreEntities:ProductModel}">  
          <Border Background="#1AFFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="5" Margin="5" Padding="5" Width="180" Height="250">  
              <Grid>  
                  <Grid.RowDefinitions>  
                      <RowDefinition Height="Auto"/>  
                      --><!-- Hình ảnh --><!--  
                      <RowDefinition Height="*"/>  
                      --><!-- Tên sản phẩm --><!--  
                      <RowDefinition Height="Auto"/>  
                      --><!-- Giá --><!--  
                      <RowDefinition Height="Auto"/>  
                      --><!-- Đánh giá --><!--  
                  </Grid.RowDefinitions>  

                  --><!-- Hình ảnh sản phẩm --><!--  
                  <Image Grid.Row="0" Stretch="Uniform" Height="120" Margin="0,0,0,5"  
                         HorizontalAlignment="Center" VerticalAlignment="Top">  
                      --><!-- Fallback nếu ảnh không tải được --><!--  
                      <Image.Source>  
                          <Binding Path="ImageSource">  
                              <Binding.TargetNullValue>  
                                  <BitmapImage UriSource="https://placehold.co/120x120/555555/FFFFFF?text=No+Image"/>  
                              </Binding.TargetNullValue>  
                          </Binding>  
                      </Image.Source>  
                  </Image>  

                  --><!-- Tên sản phẩm --><!--  
                  <TextBlock Grid.Row="1" Text="{Binding Name}" Style="{StaticResource ProductNameStyle}"  
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,5"/>  

                  --><!-- Giá sản phẩm --><!--  
                  <TextBlock Grid.Row="2" Text="{Binding Price, StringFormat='C0'}" Style="{StaticResource ProductPriceStyle}"  
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,5"/>  

                  --><!-- Đánh giá sản phẩm --><!--  
                  <TextBlock Grid.Row="3" Text="{Binding Rating}" Style="{StaticResource ProductRatingStyle}"  
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"/>  
              </Grid>  
          </Border>  
      </DataTemplate>-->  
  </Application.Resources>  
</Application>
